# Normalize text files to LF in repo; checkout as CRLF on Windows via autocrlf
* text=auto

# Keep shell scripts LF
*.sh text eol=lf

# PowerShell scripts: CRLF checkout is OK
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Python: LF in repo
*.py text eol=lf

# Markdown/config: LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
