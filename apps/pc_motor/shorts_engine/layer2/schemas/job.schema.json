{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "shorts_engine layer2 job (v0.6 minimal contract)",
  "type": "object",
  "required": ["output"],
  "properties": {
    "version": { "type": "string" },

    "output": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },

    "video": {
      "type": "object",
      "properties": {
        "duration_sec": { "type": "number", "minimum": 0.1 },
        "fps": { "type": "integer", "minimum": 1 },
        "resolution": { "type": "string", "pattern": "^[0-9]{3,4}x[0-9]{3,4}$" }
      },
      "additionalProperties": true
    },

    "script": { "type": "string" },
    "script_text": { "type": "string" },
    "text": { "type": "string" },

    "subtitles": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" }
            },
            "required": ["text"],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
